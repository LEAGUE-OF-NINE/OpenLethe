# Copy to .env and adjust. Loaded on server startup (real env vars take precedence).

# Postgres connection string (enables migrations + account/dungeon state).
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=openlethe;Username=postgres;Password=postgres

# HS256 JWT signing secret. Optional on localhost (a random ephemeral key is used if unset).
# Auth__JwtSecret=change-me-to-a-long-random-string

# Host/port to bind. Takes effect when NOT running under a launch profile (i.e. the
# published DLL, or `dotnet run --no-launch-profile`). Under `dotnet run` the launch
# profile's applicationUrl (http://localhost:5055) wins. Use 0.0.0.0 to bind all interfaces.
# ASPNETCORE_URLS=http://localhost:5055

# Environment: Development or Production. Same precedence note as ASPNETCORE_URLS — a launch
# profile sets Development, so this only applies to the published DLL / --no-launch-profile.
# ASPNETCORE_ENVIRONMENT=Development
